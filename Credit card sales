        "except FileNotFoundError:\n",
        "    print(f\"The file '{file_path}' was not found. Please upload it.\")\n",
        "    uploaded = files.upload()\n",
        "    if file_path in uploaded:\n",
        "        print(f\"File '{file_path}' uploaded. Retrying to load data.\")\n",
        "        df = pd.read_excel(file_path)\n",
        "    else:\n",
        "        print(\"Upload failed or a different file was uploaded. Please make sure to upload 'credit_card_sales_dataset.xlsx'.\")\n",
        "        # If a different file was uploaded, we could try to use it if it's the only one\n",
        "        if uploaded:\n",
        "            uploaded_file_name = list(uploaded.keys())[0]\n",
        "            print(f\"Attempting to load '{uploaded_file_name}' instead.\")\n",
        "            df = pd.read_excel(uploaded_file_name)\n",
        "        else:\n",
        "            raise # Re-raise if no suitable file was found/uploaded\n",
