        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "from google.colab import files # Added import\n",
        "\n",
        "# Load dataset\n",
        "file_path = 'credit_card_sales_dataset.xlsx'\n",
        "\n",
        "try:\n",
