PYTHON CODE 
import pandas as pd
import matplotlib.pyplot as plt

# Load data
df = pd.read_csv("churn_data.csv")

# Data Cleaning
df.dropna(inplace=True)

# Churn count
churn_count = df['Churn'].value_counts()
print(churn_count)

# Churn by Contract Type
contract_churn = df.groupby(['ContractType', 'Churn']).size().unstack()
print(contract_churn)

# Visualization
churn_count.plot(kind='bar')
plt.title("Customer Churn Distribution")
plt.xlabel("Churn")
plt.ylabel("Count")
plt.show()


CHURN_Queries.SQL 
-- Total Customers
SELECT COUNT(*) FROM churn_data;

-- Churn by Contract Type
SELECT ContractType, COUNT(*) 
FROM churn_data
WHERE Churn = 'Yes'
GROUP BY ContractType;

-- Average Monthly Charges of Churned Customers
SELECT AVG(MonthlyCharges)
FROM churn_data
WHERE Churn = 'Yes';


# Customer Churn Analysis

## Objective
To identify key factors influencing customer churn.

## Tools Used
- Python (Pandas, Matplotlib)
- SQL

## Key Findings
- Month-to-month contract customers show highest churn rate.
- Higher monthly charges correlate with churn.
- Longer tenure reduces churn probability.
